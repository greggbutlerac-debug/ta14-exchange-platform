{
  "name": "ta14-exchange-platform",
  "version": "0.3.2",
  "private": true,
  "description": "TA-14 Global Admissible Execution Exchange website and admissible execution integrity engine.",
  "type": "module",
  "packageManager": "npm@10.8.1",
  "engines": {
    "node": ">=22 <25",
    "npm": ">=10.8.1 <11"
  },
  "scripts": {
    "dev": "next dev apps/web",
    "build": "next build apps/web",
    "start": "next start apps/web",
